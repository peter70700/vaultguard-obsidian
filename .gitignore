# Build artifacts at workspace root (none today, kept for future workspace builds)
node_modules/
dist/
build/
*.tsbuildinfo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Terraform local state + secrets
# NOTE: terraform lives at packages/server/terraform/ in this monorepo, so these
# are intentionally un-anchored (match at any depth) — a leading-slash/anchored
# pattern would miss the nested path. Covers the exact May-2026 bare-`tfplan`
# leak class plus state/plan/dev-tfvars, all of which can embed resolved secrets.
terraform/environments/*.tfvars
!terraform/environments/*.tfvars.example
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup
tfplan
*.tfplan
terraform.tfvars
*.auto.tfvars

# Compiled Lambda bundles + sourcemaps (terraform/modules/lambda/.build/)
.build/
*.zip

# Environment files
.env
.env.*

# Private-only tooling — planning artifacts and AI-assistant configs must
# never be committed to a public repo. The export pipeline already filters
# these out; this list is the second line of defense for contributors who
# clone the public repo and use AI tools locally.
.planning/
.claude/
.codex/
.cursor/
.agents/
.cursorrules
.github/skills/
CLAUDE.md
AGENTS.md
CODEX.md
